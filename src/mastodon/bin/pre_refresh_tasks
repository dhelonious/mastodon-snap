#!/bin/bash -e

. "$SNAP/postgres.env"
. "$SNAP/mastodon.env"

if [ "$UPDATE_MINUTES" -gt "0" ]; then
    echo Add update announcement
    mastodon_public_announcement "The server will be updated in $UPDATE_MINUTES minutes and will be unavailable for a short time."
    echo Wait for $UPDATE_MINUTES minutes
    sleep ${UPDATE_MINUTES}m
fi

if ! is_pre_refresh_tasks_required; then
    exit 0
fi

check_setup
postgres_waitready

echo Start pre-deployment db migrations
SKIP_POST_DEPLOYMENT_MIGRATIONS=true mastodon_db_migrate

echo Create database backup
postgres_export_database "$SNAP_COMMON/database.sql"

if $UPDATE_BACKUPS; then
    echo Create update backup
    SKIP_MEDIA_EXPORT=true $SNAP/bin/export "$UPDATE_BACKUP_DIR"
fi

reset_pre_refresh_tasks_required
